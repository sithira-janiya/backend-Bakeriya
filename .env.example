# ---- Bakerya backend configuration ----
# Copy this file to ".env" and adjust as needed.

# Port the Node API + WebSocket server listens on
PORT=4000

# PocketBase instance the backend talks to
POCKETBASE_URL=http://127.0.0.1:8090

# PocketBase superuser/admin credentials (used by the backend to read/write collections).
# Create this admin the first time you run `npm run pb` (it prints a setup URL),
# or via:  ./pocketbase superuser create admin@bakerya.local your-strong-password
POCKETBASE_ADMIN_EMAIL=admin@bakerya.local
POCKETBASE_ADMIN_PASSWORD=changeme-strong-password

# Chef/admin login PIN exchanged for a JWT (replaces the old hard-coded frontend PIN)
ADMIN_PIN=1234

# Secret used to sign admin JWTs — set a long random value in production
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=12h

# Comma-separated list of allowed CORS origins (frontend dev + prod URLs)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
